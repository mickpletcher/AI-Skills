{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prior Art Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "search_terms",
    "cpc_areas",
    "references",
    "similarity_score",
    "risk_level",
    "notes"
  ],
  "properties": {
    "search_terms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cpc_areas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reference_name",
          "reference_type",
          "similarity_notes"
        ],
        "properties": {
          "reference_name": {
            "type": "string"
          },
          "reference_type": {
            "type": "string"
          },
          "similarity_notes": {
            "type": "string"
          },
          "risk_notes": {
            "type": "string"
          }
        }
      }
    },
    "similarity_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
