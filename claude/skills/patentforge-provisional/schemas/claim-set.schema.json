{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "independent_claims",
    "dependent_claims",
    "claim_dependencies",
    "fallback_positions",
    "risk_notes"
  ],
  "properties": {
    "independent_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_number",
          "claim_type",
          "text"
        ],
        "properties": {
          "claim_number": {
            "type": "integer",
            "minimum": 1
          },
          "claim_type": {
            "type": "string",
            "enum": [
              "system",
              "method",
              "apparatus",
              "software_process",
              "other"
            ]
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dependent_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_number",
          "depends_on",
          "text"
        ],
        "properties": {
          "claim_number": {
            "type": "integer",
            "minimum": 1
          },
          "depends_on": {
            "type": "integer",
            "minimum": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "claim_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_number",
          "depends_on"
        ],
        "properties": {
          "claim_number": {
            "type": "integer",
            "minimum": 1
          },
          "depends_on": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "fallback_positions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
